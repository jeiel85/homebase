<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LocalOpsBot.Tray.SettingsWindow"
        Title="LocalOps Bot Settings"
        Width="480" Height="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12">
      LocalOps Bot Settings
    </TextBlock>

    <StackPanel Grid.Row="1" Orientation="Vertical">
      <GroupBox Header="Agent Connection" Margin="0,0,0,8">
        <StackPanel>
          <TextBlock x:Name="AgentStatusText" Text="Status: Unknown" Foreground="Gray"/>
        </StackPanel>
      </GroupBox>

      <GroupBox Header="Notification Forwarding" Margin="0,0,0,8">
        <StackPanel>
          <CheckBox x:Name="ForwardingEnabledCheckBox" Content="Enable notification forwarding" IsChecked="False" Margin="0,0,0,4"/>
          <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap">
            Requires Windows notification listener permission. Restart tray app after enabling.
          </TextBlock>
        </StackPanel>
      </GroupBox>

      <GroupBox Header="About">
        <StackPanel>
          <TextBlock>LocalOps Bot v1.0.0</TextBlock>
          <TextBlock Foreground="Gray" FontSize="11">Personal Windows PC monitoring bot for Telegram</TextBlock>
        </StackPanel>
      </GroupBox>
    </StackPanel>

    <Button Grid.Row="2" Content="Close" Width="80" Height="30" HorizontalAlignment="Right" Margin="0,12,0,0"
            Click="Close_Click"/>
  </Grid>
</Window>
